                        "tag": "json-setter",
                        "props": {
                            "label": "mindmapOptions"
                        }
                    },
                    "canbind": true,
                    "propCname": "思维导图配置项",
                    "propName": "options",
                    "tips": "remind"
                },
                {
                    "tipContent": "提供收起，展开，导出等功能",
                    "configEl": {
                        "tag": "el-switch"
                    },
                    "canbind": true,
                    "propCname": "侧边栏配置",
                    "propName": "sidebar",
                    "tips": "remind"
                },
                {
                    "tipContent": "自定义XMind导出样式函数， 参数 data: XMind 数据, node: 当前节点对象, index: 当前节点索引 例子: function(data, node, index) { return { style: { background: 'red' } } }",
                    "tips": "remind",
                    "canbind": true,
                    "propCname": "自定义XMind导出样式",
                    "propName": "transformXMindStyle"
                },
                {
                    "configEl": {
                        "tag": "el-switch"
                    },
                    "canbind": true,
                    "propCname": "右键菜单",
                    "propName": "contextmenu"
                },
                {
                    "configEl": {
                        "tag": "el-switch"
                    },
                    "canbind": true,
                    "propCname": "缩放导航",
                    "propName": "navigator"
                }
